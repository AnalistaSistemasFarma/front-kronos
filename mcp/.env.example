# =============================================================================
# Configuración del servidor MCP de Kronos (SynerLink) — SOLO LECTURA
# Copie este archivo a `.env` y complete los valores. NUNCA versione `.env`.
# =============================================================================

# Puerto HTTP del servidor MCP (ruta /mcp). Default: 3020
MCP_PORT=3020

# -----------------------------------------------------------------------------
# Conexión a la base de datos (SQL Server) — reusa el esquema Prisma del repo.
#
# Por DEFECTO se REUTILIZA el mismo DATABASE_URL del usuario de la app Kronos
# (el que ya tiene permisos de escritura). El SOLO-LECTURA queda GARANTIZADO
# POR CÓDIGO: (1) toda consulta cruda pasa por `assertReadOnlySql` (src/readonly.ts),
# que solo deja ejecutar SELECT / WITH...SELECT y rechaza INSERT/UPDATE/DELETE/
# DDL/EXEC; (2) no se registra NINGUNA tool de escritura.
#
# RECOMENDACIÓN OPCIONAL (defensa en profundidad, no obligatoria): crear un
# usuario SQL de solo lectura (db_datareader) y apuntar aquí ese usuario en vez
# del de la app. Ver README §6.
# -----------------------------------------------------------------------------
DATABASE_URL="sqlserver://SERVIDOR:1433;database=Kronos_db;user=kronos_app;password=CAMBIAR;encrypt=true;trustServerCertificate=true"

# -----------------------------------------------------------------------------
# API keys por agente (JSON). El alcance (companyIds) se aplica SIEMPRE como
# filtro obligatorio: un agente con companyIds [1] jamás verá la empresa 2.
#
# Alcance ADMIN: use el comodín "*" en companyIds para que la key vea TODAS las
# empresas y TODOS los procesos (no se aplica filtro de empresa). Reserve "*"
# para agentes de confianza. Las keys con lista NUNCA pueden ampliar su alcance.
#
# Genere keys largas y aleatorias, p.ej.:  openssl rand -hex 32
# Puede usar MCP_API_KEYS (inline) o MCP_API_KEYS_FILE (ruta a un .json).
# -----------------------------------------------------------------------------
MCP_API_KEYS='[
  {"key":"REEMPLACE_POR_UNA_KEY_ALEATORIA_LARGA_1","agent":"horus-admin","companyIds":"*","role":"admin"},
  {"key":"REEMPLACE_POR_UNA_KEY_ALEATORIA_LARGA_2","agent":"bot-tesoreria","companyIds":[3],"role":"reader"}
]'
# Alternativa por archivo (no versionado):
# MCP_API_KEYS_FILE=/ruta/segura/kronos-mcp-keys.json

# Paginación
MCP_DEFAULT_PAGE_SIZE=50
MCP_MAX_PAGE_SIZE=200

# Archivo de auditoría (una línea JSON por llamada; nunca registra las keys)
MCP_AUDIT_LOG_FILE=kronos-mcp-audit.log
